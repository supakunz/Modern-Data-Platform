# ===== SOURCE DB =====
SRC_DB_HOST=postgres
SRC_DB_PORT=5432
SRC_DB_NAME=airflow
SRC_DB_USER=airflow
SRC_DB_PASSWORD=airflow

# ===== WAREHOUSE DB =====
WH_DB_HOST=postgres
WH_DB_PORT=5432
WH_DB_NAME=airflow
WH_DB_USER=airflow
WH_DB_PASSWORD=airflow

# ===== BIGQUERY (for PRD docker) =====
# Required in PRD:
# - BQ_PROJECT_ID
# Optional defaults:
# - BQ_DATASET=bronze
# - BQ_TABLE=contract_records
# - BQ_LOCATION=asia-southeast1
BQ_PROJECT_ID=project-881a9ac4-4977-437d-85b
BQ_DATASET=bronze
BQ_TABLE=contract_records
BQ_LOCATION=asia-southeast1
# No JSON key flow (recommended for local machine):
# 1) gcloud auth login
# 2) gcloud auth application-default login
# 3) gcloud config set project <YOUR_PROJECT_ID>
# 4) run make prod-up (Makefile mounts ~/.config/gcloud automatically)
# If using service-account json file inside container:
# BQ_CREDENTIALS_PATH=/home/airflow/.config/gcloud/application_default_credentials.json
# GOOGLE_APPLICATION_CREDENTIALS=/home/airflow/.config/gcloud/application_default_credentials.json

# ===== API =====
API_MODE=docker
API_CONTAINER_NAME=ml-api
